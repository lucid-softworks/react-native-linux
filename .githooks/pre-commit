#!/usr/bin/env bash
# Pre-commit gate. Hand-rolled — no husky / lint-staged dep:
#  * collect staged files by extension,
#  * run prettier / eslint / clang-format on just those files,
#  * re-stage anything the formatters touched so the commit reflects
#    the post-format content.
#
# Enabled via `git config core.hooksPath .githooks`, set automatically
# by the repo-root `prepare` script when contributors `pnpm install`.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# Filter staged files by an extension regex. --diff-filter=ACMR picks
# added/copied/modified/renamed paths (i.e. what's actually changing
# in this commit). Deletions and the special "type-change" case are
# skipped — there's nothing to format.
staged() {
  git diff --cached --name-only --diff-filter=ACMR -z \
    | tr '\0' '\n' \
    | grep -E "$1" || true
}

# pnpm exec resolves to the workspace's installed binaries. Direct
# `prettier` / `eslint` would miss the per-repo plugin chain.
PRETTIER="pnpm exec prettier --write"
ESLINT="pnpm exec eslint --fix"
CLANG_FORMAT="clang-format -i"

js_files=$(staged '\.(js|jsx|ts|tsx)$')
if [[ -n "$js_files" ]]; then
  # shellcheck disable=SC2086
  echo "$js_files" | xargs $ESLINT
  echo "$js_files" | xargs $PRETTIER
fi

cfg_files=$(staged '\.(json|md|ya?ml)$')
if [[ -n "$cfg_files" ]]; then
  echo "$cfg_files" | xargs $PRETTIER
fi

cpp_files=$(staged '\.(cpp|h)$')
if [[ -n "$cpp_files" ]]; then
  echo "$cpp_files" | xargs $CLANG_FORMAT
fi

# Re-stage every touched file. printf-with-empty-line guards against
# `xargs git add` exiting non-zero when all three lists are empty.
{
  printf '%s\n' "$js_files"
  printf '%s\n' "$cfg_files"
  printf '%s\n' "$cpp_files"
} | grep -v '^$' | xargs -r git add
