{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "draft": false,
  "prerelease": false,
  "separate-pull-requests": false,
  "plugins": ["node-workspace"],
  "packages": {
    "packages/@lucid-softworks/react-native-linux": {
      "package-name": "@lucid-softworks/react-native-linux",
      "release-type": "node",
      "extra-files": [
        {
          "type": "generic",
          "path": "/vnext/CMakeLists.txt"
        }
      ],
      "changelog-path": "CHANGELOG.md"
    },
    "packages/@lucid-softworks/cli": {
      "package-name": "@lucid-softworks/react-native-linux-cli",
      "release-type": "node",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
