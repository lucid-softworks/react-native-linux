# Keep pnpm's CAS store off the virtiofs mount when running inside the
# Lima dev VM — virtiofs doesn't support the hard-links pnpm uses, so
# without this setting pnpm falls back to a per-project `.pnpm-store/`
# inside the repo (which is huge and gets accidentally git-added).
#
# Outside the VM this resolves to a normal location under $HOME on
# macOS / Linux; the env var keeps the path portable.
store-dir=${HOME}/.local/share/pnpm/store

# Use hoisted node-linker to avoid relying on symlinks (which also
# behave inconsistently across virtiofs).
node-linker=hoisted
