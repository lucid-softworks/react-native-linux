node_modules/
**/node_modules/
**/lib/
**/dist/
**/build/
vnext/build/
vnext/codegen/
packages/**/templates/**
# Playground runtime ships its own per-app babel.config.js; root-level
# @babel/eslint-parser can't resolve it from this depth, so let the
# playground's own lint pipeline cover these.
apps/playground/runtime/
# Same shape for the Expo umbrella package: it's plain CJS JS, not
# part of any babel-eslint-parsed project. The shims are exercised in
# the playground (which has its own lint setup).
packages/@lucid-softworks/react-native-linux-expo/
# Metro configs are CJS at consumer projects — they don't see the
# repo-root @babel/eslint-parser config either.
**/metro.config.js
# Metro smoke-test fixture under apps/playground; bundled by the
# scripts/test-metro-resolve.mjs driver, not by any eslint-aware tool.
apps/playground/__test_metro_resolve__/
