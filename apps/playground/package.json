    "@react-native/metro-config": "^0.76.0",
    "@swc/core": "^1.15.40",
    "@types/react": "^18.2.0",
    "babel-jest": "^29.7.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
